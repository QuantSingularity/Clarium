# ─── Clarium RegTech Compliance Module ────────────────────────────────────────
# Copy to .env and fill in values. All defaults work out of the box.

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=clarium
POSTGRES_PASSWORD=clarium_secret
POSTGRES_DB=clarium
DATABASE_URL=postgresql+asyncpg://clarium:clarium_secret@postgres:5432/clarium

# Redis
REDIS_URL=redis://redis:6379/0

# App
SECRET_KEY=change-me-in-production-use-a-32char-string
ENVIRONMENT=development
LOG_LEVEL=INFO
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# OCR Service (mock by default)
OCR_SERVICE_URL=mock
OCR_CONFIDENCE_THRESHOLD=0.80

# KYC
KYC_SCORE_THRESHOLD_VERIFIED=0.75
KYC_SCORE_THRESHOLD_REVIEW=0.50

# AML Thresholds
AML_AMOUNT_THRESHOLD=10000
AML_VELOCITY_WINDOW_MINUTES=60
AML_VELOCITY_MAX_TRANSACTIONS=10
AML_HIGH_RISK_SCORE=0.70

# Webhook
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_BACKOFF_SECONDS=30
WEBHOOK_TIMEOUT_SECONDS=10

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rules directory
RULES_DIR=/app/rules/jurisdictions
